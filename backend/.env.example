# ── Variáveis de ambiente do GLM ─────────────────────────────
# Copie este arquivo para .env e preencha os valores

# Banco de dados
# SQLite (demo local):
DATABASE_URL=sqlite:///./glm.db
# MySQL (produção):
# DATABASE_URL=mysql+pymysql://usuario:senha@localhost:3306/glm

# IA - Anthropic (claude-haiku, mais barato)
# Sem essa chave, o sistema usa respostas heurísticas (modo demo)
ANTHROPIC_API_KEY=sua_chave_aqui

# Ambiente
ENVIRONMENT=development
PORT=8000
